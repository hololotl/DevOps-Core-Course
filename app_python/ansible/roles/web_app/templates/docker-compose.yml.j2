---
services:
  {{ web_app_name }}:
    image: "{{ web_app_docker_image }}:{{ web_app_docker_tag }}"
    container_name: "{{ web_app_name }}"
    ports:
      - "{{ web_app_port }}:{{ web_app_internal_port }}"
    environment:
      APP_PORT: "{{ web_app_internal_port }}"
{% if app_secret_key is defined %}
      APP_SECRET_KEY: "{{ app_secret_key }}"
{% endif %}
{% for key, value in web_app_environment.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
    restart: "{{ web_app_restart_policy }}"
    networks:
      - app_net

networks:
  app_net:
    driver: bridge
