---
services:
  {{ app_name }}:
    image: "{{ docker_image }}:{{ docker_tag }}"
    container_name: "{{ app_name }}"
    ports:
      - "{{ app_port }}:{{ app_internal_port }}"
    environment:
      APP_PORT: "{{ app_internal_port }}"
{% if app_secret_key is defined %}
      APP_SECRET_KEY: "{{ app_secret_key }}"
{% endif %}
{% for key, value in app_environment.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
    restart: "{{ restart_policy }}"
    networks:
      - app_net

networks:
  app_net:
    driver: bridge
